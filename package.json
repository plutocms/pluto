    "tailwindcss": "^4.3.2",
    "typescript": "7.0.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.7"
  },
  "overrides": {
    "eslint-flat-config-utils": "^3.2.0"

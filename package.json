  },
  "bugs": {
    "url": "https://github.com/plutocms/pluto/issues"
  },
  "keywords": [
    "pluto",
    "cms",
    "nuxt",
    "vue",
    "wordpress"
  ],
  "main": "./nuxt.config.ts",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --no-fork",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prettier": "prettier --write .",

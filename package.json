    "@vueuse/nuxt": "^14.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/simple-icons": "^1.2.89",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/ui": "^4.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "mysql2": "^3.22.6",

{
  "name": "plutocms",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --no-fork",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "bun run supabase-types && nuxt prepare",
    "supabase-types": "bun ./layers/supabase/scripts/supabase-typegen",
    "prettier": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^2.1.0",
    "@nuxt/ui": "^4.1.0",
    "@nuxtjs/supabase": "1.6.2",
    "@tailwindcss/vite": "^4.1.17",
    "@vueuse/integrations": "^14.0.0",
    "@vueuse/nuxt": "^14.0.0",
    "change-case": "^5",
    "mysql2": "^3.15.3",
    "nuxt": "^4.2.1",
    "reka-ui": "^2.6.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.17",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.1.0",
    "@iconify-json/lucide": "^1.2.71",
    "@iconify-json/simple-icons": "^1.2.61",
    "@nuxt/eslint": "^1.8.0",
    "@types/bun": "^1.3.1",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "esbuild",
    "unrs-resolver",
    "vue-demi"
  ]
}

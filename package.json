{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "bun run supabase-types && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "supabase-types": "bun ./scripts/supabase-typegen",
    "prettier": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "nuxt prepare && vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.11.4",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/ui": "^3.2.0",
    "@nuxtjs/supabase": "^1.5.3",
    "@nuxtjs/tailwindcss": "7.0.0-beta.0",
    "@vueuse/integrations": "^13.5.0",
    "@vueuse/nuxt": "^13.5.0",
    "change-case": "^5",
    "nuxt": "^4.0.0",
    "reka-ui": "^2.4.0",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.17.0",
    "@iconify-json/lucide": "^1.2.57",
    "@iconify-json/simple-icons": "^1.2.41",
    "@nuxt/eslint": "^1.5.2",
    "@types/bun": "^1.2.18",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.8.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide",
    "unrs-resolver"
  ],
  "resolutions": {
    "nitropack": "2.12.3"
  }
}
